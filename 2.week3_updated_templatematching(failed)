BASE_SPEED = 0.4 # 严格按你的要求，丝毫不改
PIVOT_POWER = 0.55 # 严格按你的要求，丝毫不改
MIN_SPEED = 0.28
KP = 0.4 # 严格按你的要求，丝毫不改
KD = 0.30
TARGET_CENTER = FRAME_WIDTH // 2 # 320
SHARP_TURN_THRESHOLD = 60
MIN_LINE_AREA = 800
LINE_ROI_Y = int(FRAME_HEIGHT * 0.58) # bottom 42%

LOWER_BLACK = np.array([0, 0, 0 ])
UPPER_BLACK = np.array([180, 255, 90])
LOWER_RED1 = np.array([0, 120, 60]); UPPER_RED1 = np.array([10, 255, 255])
LOWER_RED2 = np.array([170, 120, 60]); UPPER_RED2 = np.array([180, 255, 255])

last_error = 0

def get_centroid_from_mask(mask):
roi = mask[LINE_ROI_Y:, :]
M = cv2.moments(roi)
if M['m00'] > MIN_LINE_AREA:
return int(M['m10'] / M['m00'])
return None

def get_line_centroid(frame_bgr):
hsv = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2HSV)
red_mask = cv2.bitwise_or(
cv2.inRange(hsv, LOWER_RED1, UPPER_RED1),
cv2.inRange(hsv, LOWER_RED2, UPPER_RED2)
)
black_mask = cv2.inRange(hsv, LOWER_BLACK, UPPER_BLACK)
cx = get_centroid_from_mask(red_mask)
if cx is not None:
return cx, 'red', red_mask
cx = get_centroid_from_mask(black_mask)
if cx is not None:
return cx, 'black', black_mask
return None, 'none', black_mask

def compute_steering(cx):
global last_error
error = cx - TARGET_CENTER
derivative = error - last_error
last_error = error
if abs(error) > SHARP_TURN_THRESHOLD:
return (-PIVOT_POWER, PIVOT_POWER) if error > 0 else (PIVOT_POWER, -PIVOT_POWER)
norm = error / SHARP_TURN_THRESHOLD
control = KP * norm + KD * (derivative / SHARP_TURN_THRESHOLD)
left = BASE_SPEED - control * BASE_SPEED
right = BASE_SPEED + control * BASE_SPEED
if left > 0: left = max(left, MIN_SPEED)
if right > 0: right = max(right, MIN_SPEED)
return (left, right)

