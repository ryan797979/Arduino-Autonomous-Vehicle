# 8. FSM ACTION (100% ORIGINAL, UNCHANGED)
# ═══════════════════════════════════════════════════════════
def apply_symbol_action(label, now):
global state, action_start_time, last_detection_time

if label in ('qr_code', 'fingerprint'):
print(f" [{label.upper()}] detected — logged, continuing.")
last_detection_time = now
return

if label in ('arrow_up', 'arrow_down'):
print(f" [{label.upper()}] detected — no action.")
last_detection_time = now
return

action_map = {
'warning' : 'STOP',
'button_press' : 'STOP',
'recycle' : 'TURN_180',
'arrow_left' : 'TURN_LEFT',
'arrow_right' : 'TURN_RIGHT',
}
new_state = action_map.get(label)
if new_state is None:
return
if new_state != state:
print(f" FSM: {state} → {new_state} [{label}]")
state = new_state
action_start_time = now
last_detection_time = now
else:
last_detection_time = now

# ═══════════════════════════════════════════════════════════
# 9. MAIN LOOP (100% ORIGINAL, UNCHANGED)
# ═══════════════════════════════════════════════════════════
frame_count = 0
last_debug = None
print(f"\nRobot starting — state: {state}")
print(f"Templates: {list(templates.keys())}")
print("Press Q to quit.\n")

try:
while True:
frame_rgb = picam2.capture_array()
frame_rgb = cv2.flip(frame_rgb, 0)
frame = cv2.cvtColor(frame_rgb, cv2.COLOR_RGB2BGR)

cx, line_type, line_mask = get_line_centroid(frame)

if frame_count % N_FRAMES == 0:
now = time.time()
detections, last_debug = detect_symbols(frame)
cur_labels = set(d["label"] for d in detections)

# 无有效检测，强制清零所有计数，杜绝噪点累积
if len(detections) == 0:
stable_counts.clear()
else:
# 未检测到的标签，立即清零
for lbl in list(stable_counts.keys()):
if lbl not in cur_labels:
stable_counts[lbl] = 0
# 仅对检测到的标签累加计数
for det in detections:
lbl = det["label"]
stable_counts[lbl] = stable_counts.get(lbl, 0) + 1
# 必须连续稳定检测到，才触发动作
if (stable_counts[lbl] >= STABLE_NEEDED
and now - last_detection_time > COOLDOWN):
print(f"[Frame {frame_count}] CONFIRMED: {lbl} score: {det['score']}")
apply_symbol_action(lbl, now)
stable_counts[lbl] = 0

now = time.time()

if state == 'LINE_FOLLOW':
if cx is not None:
left, right = compute_steering(cx)
set_motor_speed(left, right)
else:
spin = 0.45 if last_error > 0 else -0.45
set_motor_speed(-spin, spin)

elif state == 'STOP':
set_motor_speed(0, 0)
if now - action_start_time > STOP_DURATION:
print(" FSM: STOP → LINE_FOLLOW (5s elapsed)")
state = 'LINE_FOLLOW'

elif state == 'TURN_180':
set_motor_speed(-PIVOT_POWER, PIVOT_POWER)
if now - action_start_time > TURN_180_DURATION:
print(" FSM: TURN_180 → LINE_FOLLOW")
state = 'LINE_FOLLOW'

elif state == 'TURN_LEFT':
set_motor_speed(-PIVOT_POWER, PIVOT_POWER)
if now - action_start_time > TURN_90_DURATION:
print(" FSM: TURN_LEFT → LINE_FOLLOW")
state = 'LINE_FOLLOW'

elif state == 'TURN_RIGHT':
set_motor_speed(PIVOT_POWER, -PIVOT_POWER)
if now - action_start_time > TURN_90_DURATION:
print(" FSM: TURN_RIGHT → LINE_FOLLOW")
state = 'LINE_FOLLOW'

cv2.imshow("Line Mask", line_mask)
if last_debug is not None:
cv2.imshow("Symbols", last_debug)
if cv2.waitKey(1) & 0xFF == ord('q'):
print("Q pressed — stopping.")
break

frame_count += 1

# ═══════════════════════════════════════════════════════════
# 10. SAFE SHUTDOWN (100% ORIGINAL, UNCHANGED)
# ═══════════════════════════════════════════════════════════
except KeyboardInterrupt:
print("\nCtrl+C — shutting down.")
finally:
set_motor_speed(0, 0)
picam2.stop()
cv2.destroyAllWindows()
print("Motors stopped. Camera released. Done.")
